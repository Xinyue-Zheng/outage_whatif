---
config:
  flowchart:
    curve: linear
---
graph TD;
	__start__([<p>__start__</p>]):::first
	advance(advance)
	adjudicate_lifecycle(adjudicate_lifecycle)
	assess(assess)
	expand_boundary(expand_boundary)
	stop_check(stop_check)
	build_tables(build_tables)
	seat1(seat1)
	seat2(seat2)
	execute(execute)
	__end__([<p>__end__</p>]):::last
	__start__ --> advance;
	adjudicate_lifecycle --> assess;
	advance -.-> __end__;
	advance -.-> adjudicate_lifecycle;
	assess -.-> expand_boundary;
	assess -.-> stop_check;
	build_tables --> seat1;
	seat1 -.-> __end__;
	seat1 -.-> seat2;
	seat2 -.-> __end__;
	seat2 -.-> execute;
	stop_check -.-> __end__;
	stop_check -.-> build_tables;
	execute --> __end__;
	expand_boundary --> __end__;
	classDef default fill:#f2f0ff,line-height:1.2
	classDef first fill-opacity:0
	classDef last fill:#bfb6fc
